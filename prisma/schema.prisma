generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A story (user story) from Azure DevOps — lightweight parent reference for context
model Story {
  id       Int    @id    // Azure DevOps work item ID
  title    String
  azureUrl String        // Azure DevOps work item URL

  tasks Task[]
}

/// A task work item — the primary pipeline entity
model Task {
  id           Int       @id                    // Azure DevOps work item ID
  title        String
  storyId      Int?                             // Parent story work item ID (optional)
  state        String    @default("PROFILE_ASSIGNMENT") // GridState enum value
  profileKey   String?                          // Key from profile.json
  worktreePath String?                          // Absolute path to git worktree
  sessionId    String?                          // Copilot CLI session ID
  model        String?                          // Copilot model ID (e.g. 'claude-opus-4.6')
  prUrl        String?                          // GitHub pull request URL
  prMerged     Boolean   @default(false)        // Whether the task PR has been merged
  azureUrl     String                           // Azure DevOps work item URL
  disabled     Boolean   @default(false)        // Whether item is disabled in the grid
  skipCopilot  Boolean   @default(false)        // Skip automatic copilot session (manual mode)
  prUpdated    Boolean   @default(false)        // Flag: GitHub webhook indicated PR update
  completedAt  DateTime?                        // When the task was moved to COMPLETED
  errorMessage String?                          // Last error message (null = no error)
  errorAt      DateTime?                        // When the last error occurred
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  story Story? @relation(fields: [storyId], references: [id], onDelete: SetNull)

  @@index([state])
  @@index([storyId])
}

/// Flags controlling which cron job steps can execute
model CronState {
  id                    Int     @id @default(1) // Singleton row
  syncEnabled           Boolean @default(true)  // Can the Azure sync step run?
  taskExecutionEnabled  Boolean @default(true)  // Can the task execution step run?
  prCheckEnabled        Boolean @default(true)  // Can the PR check step run?
  lastRunAt             DateTime?               // Last time the cron job ran
}
