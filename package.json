{
  "name": "hitl",
  "version": "0.1.0",
  "description": "Human-in-the-Loop Agentic Development Orchestrator",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:mock": "cross-env HITL_ENABLE_MOCK_REPO=true electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "typecheck:main": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:preload": "tsc --noEmit -p tsconfig.preload.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.renderer.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:preload && npm run typecheck:renderer",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,html}": "prettier --write"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "@tanstack/react-query": "^4.36.1",
    "@tanstack/react-table": "^8.20.6",
    "@trpc/client": "^10.45.2",
    "@trpc/react-query": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "better-sqlite3": "12.8.0",
    "dotenv": "17.3.1",
    "electron-trpc": "^0.7.1",
    "electron-updater": "6.8.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "styled-components": "6.3.12",
    "superjson": "^2.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "10.1.0",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jsdom": "27.0.1",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "prisma": "6.19.2",
    "tsx": "4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.58.0",
    "vite": "^6.0.5",
    "vitest": "4.1.2"
  }
}
